# Files excluded from trainer.zip (hafnia trainer create / create-zip).
# Patterns follow .gitignore syntax.

# Defaults from hafnia.utils.DEFAULT_IGNORE_SPECIFICATION, kept explicit so we own the list.
*.jpg
*.png
# (RF-DETR pretrain weight files live in weights/ — they MUST be included so the
# offline platform can find them. .pth/.pt are NOT in the global ignore list.)
*.py[cod]
*_cache/
**.egg-info/
.data
.git
.venv
.vscode
__pycache__
trainer.zip
tests
wandb

# Project-specific
visualization/
.gitignore
README.md
commands.txt
trainer_instruction.txt
.monitor.py
.monitor.log
.debug_out
.debug_out2
.debug_mlruns
.vram_probe.py
state.json

# Separate ConvNeXt/mmdet trainer — packaged on its own from trainer-convnext/, NOT used by this
# RF-DETR Large trainer (root Dockerfile never COPYs it). It was accidentally swept into trainer.zip
# before, adding ~145 MB of dead weights + a conflicting second Dockerfile.
trainer-convnext/

# Non-runtime project material: docs/notes and local API tooling are not needed inside the trainer.
docs/
tools/

# Checkpoints/artifacts downloaded back FROM the platform (e.g. artifacts/v20/) — never ship them.
artifacts/

# Submission files assembled at repo root (predictions + zip) — outputs, never trainer inputs.
predictions_test.json
submission_*.zip
# Stray ensemble/inference .zip bundles at repo root (the submission_*.zip pattern misses them).
# No .zip is ever a trainer input — trainer.zip itself is already excluded above.
inference_ensemble.zip
*.zip
# .tar.gz submission/output bundles the *.zip pattern misses (e.g. submission_v25.tar.gz,
# outputs-*.tar.gz). No .tar.gz is ever needed at training time, so exclude them all.
*.tar.gz
# Downloaded experiment-outputs scratch dir (configuration/environment/experiment.parquet).
v25/
*Zone.Identifier

# RF-DETR baggage we never need at training time
rf-detr/docs/
rf-detr/notebooks/
rf-detr/tests/
rf-detr/CHANGELOG.md
rf-detr/CITATION.cff
rf-detr/mkdocs.yaml

# BDD100K Cascade-R-CNN checkpoint — kept locally for reference / future experiments
# but NOT used by the current RF-DETR Large trainer, so we exclude it from trainer.zip
# (saves ~834 MB of upload).
weights/cascade_rcnn_convnext-s_fpn_fp16_3x_det_bdd100k.pth
weights/PROVENANCE.md

# Checkpoints NOT used by the DINOv3 run (it warm-starts from rf-detr-large-2026.pth and loads the
# DINOv3 backbone from weights/dinov3-vits16-pretrain-lvd1689m/). These are recoverable from the
# platform's model artifacts, so we exclude them to shrink the trainer.zip upload by ~460 MB.
# NOTE: weights/v5_best_ema.pth is the warm-start base for the fisheye/night run (v10) — it MUST
# ship, so it is intentionally NOT excluded here.
weights/v6_best_ema.pth
weights/v6_best_regular_ep3.pth

# Recovered ensemble-MEMBER checkpoints (v16 RF-DETR @1120, VFNet R-50, ConvNeXt-T). Used only to
# REGENERATE the ensemble's pseudo-labels (offline / in their own mmdet trainers), NOT by the RF-DETR
# self-training student — which reads the slimmed weights/pseudo_test_labels.json and warm-starts from
# weights/v28_best_ema.pth. Exclude to keep trainer.zip lean (~580 MB). Recoverable any time from the
# platform /model artifacts (v16_fixed, vfnet_r50_fpn_eccv_v17b, convnext_v2_v2).
weights/v16_best_ema.pth
weights/vfnet_eccv_best.pth
weights/convnext_dima.pth

# Stray Ultralytics auto-download checkpoints (yolo11l/n/x.pt, yolo26l.pt) that land in the repo
# root + weights/ during YOLO benchmarking. The RF-DETR DINOv3 run needs none of them (it uses
# rf-detr-large-2026.pth and the DINOv3 .safetensors), so exclude every *.pt to keep trainer.zip
# lean. RF-DETR's own pretrain weights are .pth/.safetensors, never .pt — so this is safe.
*.pt
