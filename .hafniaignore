# Files excluded from trainer.zip (hafnia trainer create / create-zip).
# Patterns follow .gitignore syntax.

# Defaults from hafnia.utils.DEFAULT_IGNORE_SPECIFICATION, kept explicit so we own the list.
*.jpg
*.png
# (RF-DETR pretrain weight files live in weights/ — they MUST be included so the
# offline platform can find them. .pth/.pt are NOT in the global ignore list.)
*.py[cod]
*_cache/
**.egg-info/
.data
.git
.venv
.vscode
__pycache__
trainer.zip
tests
wandb

# Project-specific
visualization/
.gitignore
README.md
commands.txt
trainer_instruction.txt
.monitor.py
.monitor.log
.debug_out
.debug_out2
.debug_mlruns
.vram_probe.py
state.json

# RF-DETR baggage we never need at training time
rf-detr/docs/
rf-detr/notebooks/
rf-detr/tests/
rf-detr/CHANGELOG.md
rf-detr/CITATION.cff
rf-detr/mkdocs.yaml

# BDD100K Cascade-R-CNN checkpoint — kept locally for reference / future experiments
# but NOT used by the current RF-DETR Large trainer, so we exclude it from trainer.zip
# (saves ~834 MB of upload).
weights/cascade_rcnn_convnext-s_fpn_fp16_3x_det_bdd100k.pth
weights/PROVENANCE.md
